{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vibe-check",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-09",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "containers": [
    {
      "class_name": "ReviewBackend",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ReviewBackend",
        "name": "REVIEW_BACKEND"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["ReviewBackend"],
      "tag": "v1"
    }
  ],
  "routes": [
    {
      "pattern": "vibe-check.thatcanadian.dev",
      "custom_domain": true
    }
  ],
  "secrets": {
    "required": [
      "CONVEX_HTTP_SECRET",
      "OPENROUTER_API_KEY",
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_CHAT_ID"
    ]
  },
  "vars": {
    "APP_ALLOWED_HOSTS": "vibe-check.thatcanadian.dev",
    "APP_PUBLIC_URL": "https://vibe-check.thatcanadian.dev",
    "CONVEX_URL": "https://energetic-partridge-813.convex.cloud",
    "JOB_DATA_DIR": "/tmp/vibe-check/jobs",
    "JOB_WORKER_CONCURRENCY": "4",
    "MAX_UPLOAD_MB": "200",
    "OPENROUTER_MODEL": "deepseek/deepseek-v4-flash",
    "OPENROUTER_VISION_ENABLED": "true",
    "OPENROUTER_VISION_MODEL": "minimax/minimax-m3",
    "OPENROUTER_VISION_MAX_FRAMES": "12",
    "OPENROUTER_VISION_MAX_IMAGE_EDGE": "1024",
    "OPENROUTER_VISION_JPEG_QUALITY": "75",
    "OPENROUTER_STT_MODEL": "openai/whisper-large-v3",
    "OPENROUTER_STT_LANGUAGE": "",
    "OPENROUTER_STT_CHUNK_SECONDS": "10",
    "OPENROUTER_STT_MAX_CHUNKS": "30"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
